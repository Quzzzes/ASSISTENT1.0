# Порт веб-сервера (по умолчанию 3080)
PORT=3080

# OpenClaw Gateway — для отправки уведомлений в Telegram
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_HOOK_TOKEN=ваш_токен_webhook
OPENCLAW_TELEGRAM_TO=123456789

# Несколько получателей — через запятую
# OPENCLAW_TELEGRAM_TO=111111111,222222222

# Интервал проверки напоминаний в миллисекундах (по умолчанию 60000 = 1 мин)
# CHECK_INTERVAL_MS=60000

# Токен Telegram‑бота для управления задачами (BotFather)
TELEGRAM_BOT_TOKEN=ваш_токен_бота

# Рекомендуемо: уведомления отправляются напрямую через Telegram Bot API,
# если TELEGRAM_BOT_TOKEN задан и в задаче есть telegramTo.
# OPENCLAW_* нужны только как fallback.

# URL API задач (если сервер на другом хосте/порту)
# TASKS_API_URL=http://localhost:3080/api/tasks
